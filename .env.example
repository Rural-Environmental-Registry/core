# =============================================================================
# RER - Rural Environmental Registry
# Configuração de Ambiente (Standalone Deploy)
# =============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Configuração Geral
# -----------------------------------------------------------------------------
# Protocolo (http para desenvolvimento local, https para produção)
HTTP_HTTPS=http

# Hostname do servidor (ex: meudominio.gov.br)
HOSTNAME_DNS=localhost

# URL base da aplicação (deixe vazio para raiz, ou /rer para subpath)
BASE_URL=

# URL completa (gerada automaticamente)
APP_URL=${HTTP_HTTPS}://${HOSTNAME_DNS}${BASE_URL}

# Porta HTTP do proxy reverso
RER_HTTP_PORT=80

# URLs permitidas no CORS do backend
FRONTEND_URLS=${HTTP_HTTPS}://${HOSTNAME_DNS},http://localhost:5173

# -----------------------------------------------------------------------------
# Core Backend
# -----------------------------------------------------------------------------
CORE_BACKEND_DB_NAME=car_db
CORE_BACKEND_DB_USER=car_user
CORE_BACKEND_DB_PASSWORD=car_pass
CORE_BACKEND_API_HASH_PREFIX=BR
CORE_BACKEND_API_RECEIPT_LOGO_PATH=images/govbr.svg
CORE_BACKEND_API_WATERMARK_IMAGE_PATH=images/unofficial.svg
CORE_BACKEND_API_GENERAL_INFORMATION_RECEIPT_PATH=reports/GENERAL_INFORMATION.txt
CORE_BACKEND_API_REPORT_PARAMS_RECEIPT_JSON=reports/report_params.json
CORE_BACKEND_API_DEFAULT_LOCATION_ZONE=Europe/London

# -----------------------------------------------------------------------------
# Authentication (Keycloak)
# -----------------------------------------------------------------------------
AUTH_DB_NAME=keycloak
AUTH_DB_USER=keycloak
AUTH_DB_PASSWORD=senhaSegura
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Calculation Engine
# -----------------------------------------------------------------------------
CALC_ENGINE_DB_NAME=calculator_engine
CALC_ENGINE_DB_USER=calculator_engine
CALC_ENGINE_DB_PASSWORD=calculator_engine

CALC_POSTGIS_DB_NAME=postgis_calculator
CALC_POSTGIS_DB_USER=postgis_calculator
CALC_POSTGIS_DB_PASSWORD=postgis_calculator

# -----------------------------------------------------------------------------
# GeoServer
# -----------------------------------------------------------------------------
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver
GEOSERVER_WORKSPACE_NAME=rer
GEOSERVER_DATASTORE_NAME=db
